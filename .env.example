# ZAO Paperz bot environment - copy to .env and fill values.
#
# IMPORTANT: chmod 600 .env after filling. Never commit .env.

# ----- Discord -----
# From discord.com/developers/applications -> your app -> Bot tab -> Reset Token.
DISCORD_BOT_TOKEN=
# From the same app's General Information tab (Application ID).
DISCORD_APP_ID=
# NOT set on purpose: this bot is meant to install across MULTIPLE servers
# (global slash commands), unlike ZAOscribe which is locked to one guild.
# If you ever want to test commands instantly in one server before they
# propagate globally (~1hr), set DISCORD_TEST_GUILD_ID for dev only.
DISCORD_TEST_GUILD_ID=

# ----- Source of truth -----
# The live FAQPage JSON-LD this bot reads from. Do not hardcode the Q&A here -
# read directly from the canonical page so this bot never drifts from the
# website (see PR #174/#176/#177 - three separate copies of the same facts
# is exactly how the Gini/holder-count bug happened).
ZAO_FAQ_URL=https://www.thezao.xyz/what-is-the-zao
# Re-fetch interval in minutes. Default 360 (6h) - FAQ content doesn't change hourly.
FAQ_REFRESH_MINUTES=360

# ----- Logging -----
LOG_LEVEL=info
NODE_ENV=production

# ----- Status dashboard (optional) -----
# Enables the bot to report heartbeats/command events to Supabase for the
# dashboard/ Next.js app to read. If unset, the bot runs exactly as before -
# reporting is a no-op. Uses the SAME project as the other ZAO bots' status
# tables (etwvzrmlxeobinrlytza), service-role key required (these tables
# have RLS enabled with no anon-accessible policies).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Papers RAG (optional) -----
# Enables the periodic reindex job that embeds every ZAO paper's content
# into public.paper_sections (Zuke Supabase project, yhpszfepoerqgnewukkh)
# for semantic search via public.match_paper_sections(). If unset, the
# reindex loop no-ops - the bot runs exactly as before.
#
# IMPORTANT: this is a DIFFERENT Supabase project than the status dashboard
# above, so it gets its OWN, separate env vars - never reuse SUPABASE_URL/
# SUPABASE_SERVICE_ROLE_KEY here, that would point the RAG reindex at the
# cowork project (wrong tables) or the dashboard at the Zuke project (also
# wrong tables), depending on which one you set last.
RAG_SUPABASE_URL=
RAG_SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
